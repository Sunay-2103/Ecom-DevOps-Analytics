# ============================================================
# E-Commerce DevOps Analytics — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values.
# cp .env.example .env

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=ecom_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ecom_db
POSTGRES_PORT=5433

# ── Backend ──────────────────────────────────────────────────
DATABASE_URL=postgresql://ecom_user:change_me_in_production@database:5432/ecom_db
PYTHONPATH=/app

# ── Frontend ─────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000

# ── Docker Hub (optional — for CI/CD push) ───────────────────
# DOCKER_USERNAME=your_dockerhub_username
# DOCKER_PASSWORD=your_dockerhub_token

# ── ETL Pipeline ─────────────────────────────────────────────
ETL_OUTPUT_DIR=/app/exports
